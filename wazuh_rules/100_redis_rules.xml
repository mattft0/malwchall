<!--
  ╔══════════════════════════════════════════════════════════════════╗
  ║  BlueTeam Challenge — Redis 7 Detection Rules                   ║
  ║  IDs: 100300 – 100319                                           ║
  ╚══════════════════════════════════════════════════════════════════╝
  Covers:
    - Unauthenticated access / NOAUTH errors
    - CONFIG SET / replication slave abuse (RCE)
    - FLUSHALL / FLUSHDB (data destruction)
    - Lua scripting abuse (EVAL)
    - DEBUG commands (OBJECT / RELOAD)
    - Crontab / SSH key injection via Redis
-->
<group name="redis,blueteam,">

  <!-- ── Base rule ─────────────────────────────────────────────── -->
  <rule id="100300" level="3">
    <decoded_as>syslog</decoded_as>
    <match>redis-server|redis|REDIS</match>
    <description>Redis: generic log entry</description>
    <group>redis,</group>
  </rule>

  <!-- ── Auth failure / no auth ─────────────────────────────────── -->
  <rule id="100301" level="8">
    <if_sid>100300</if_sid>
    <match>NOAUTH Authentication required|ERR invalid password|AUTH failed|without any password</match>
    <description>Redis: Authentication failure or unauthenticated access</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>redis,authentication_failed,</group>
  </rule>

  <!-- Brute force -->
  <rule id="100302" level="12" frequency="5" timeframe="60">
    <if_matched_sid>100301</if_matched_sid>
    <same_source_ip/>
    <description>Redis: Brute-force attack detected</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>redis,brute_force,</group>
  </rule>

  <!-- ── CONFIG SET abuse (cron/SSH injection RCE) ─────────────── -->
  <rule id="100303" level="15">
    <if_sid>100300</if_sid>
    <regex>(?i)(CONFIG\s+SET\s+(dir|dbfilename|requirepass|save|bind|slaveof|replicaof)|SLAVEOF\s+|REPLICAOF\s+)</regex>
    <description>Redis: Dangerous CONFIG SET or replication command — possible RCE attempt</description>
    <mitre>
      <id>T1505</id>
    </mitre>
    <group>redis,rce,attack,</group>
  </rule>

  <!-- ── Data destruction ───────────────────────────────────────── -->
  <rule id="100304" level="14">
    <if_sid>100300</if_sid>
    <regex>(?i)(FLUSHALL|FLUSHDB|DEBUG\s+RELOAD|DEBUG\s+LOADAOF|BGREWRITEAOF)</regex>
    <description>Redis: Destructive or debug command detected</description>
    <mitre>
      <id>T1485</id>
    </mitre>
    <group>redis,data_destruction,</group>
  </rule>

  <!-- ── Lua script abuse (EVAL) ───────────────────────────────── -->
  <rule id="100305" level="12">
    <if_sid>100300</if_sid>
    <regex>(?i)(EVAL\s+|EVALSHA\s+|SCRIPT\s+LOAD)</regex>
    <description>Redis: Lua script execution — potential code execution</description>
    <mitre>
      <id>T1059</id>
    </mitre>
    <group>redis,code_execution,</group>
  </rule>

  <!-- ── Redis listening on 0.0.0.0 without auth ───────────────── -->
  <rule id="100306" level="12">
    <if_sid>100300</if_sid>
    <match>bind 0.0.0.0|Running in no-auth mode</match>
    <description>Redis: Exposed on all interfaces without authentication — critical misconfiguration</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>redis,misconfiguration,</group>
  </rule>

  <!-- ── Module load (potential plugin RCE) ────────────────────── -->
  <rule id="100307" level="14">
    <if_sid>100300</if_sid>
    <regex>(?i)(MODULE\s+LOAD|loadmodule)</regex>
    <description>Redis: External module load — possible malicious plugin</description>
    <mitre>
      <id>T1547</id>
    </mitre>
    <group>redis,rce,</group>
  </rule>

</group>
